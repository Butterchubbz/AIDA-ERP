{
  "name": "temp-aida",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "start": "echo \"Run PocketBase first (see POCKETBASE_SETUP_GUIDE.md), then run \" && vite",
    "start-pocketbase": "echo \"Place pocketbase.exe in a folder and run: .\\pocketbase.exe serve\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "images:convert": "node ./scripts/convert-images.mjs",
    "release:create": "node ./scripts/create-release.mjs",
    "test": "vitest",
    "preview": "vite preview",
    "smoke:test": "playwright test test/smoke --project=chromium"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@types/papaparse": "^5.3.16",
    "express": "^5.1.0",
    "papaparse": "^5.5.3",
    "pocketbase": "^0.26.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.1",
    "recharts": "^3.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.55.1",
    "@sentry/browser": "^7.37.0",
    "@sentry/cli": "^2.0.0",
    "@sentry/tracing": "^7.37.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "archiver": "^5.3.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.6",
    "prettier": "^2.8.8",
    "rollup-plugin-visualizer": "^6.0.3",
    "sharp": "^0.32.0",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^4.1.13",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  }
}
