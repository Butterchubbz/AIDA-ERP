# Copy this to .env.local and fill in real values
# Never commit .env.local

# Backend API URL
VITE_API_URL=http://localhost:3001

# Shared encryption key (must match packages/backend/.env)
VITE_ENCRYPTION_KEY=replace-with-64-hex-characters

# Personal mode auto-login password
VITE_LOCAL_OWNER_PASSWORD=your_password_here

# Debug mode
VITE_DEBUG=false

# Sentry DSN (optional)
VITE_SENTRY_DSN=
