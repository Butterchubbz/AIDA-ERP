# PocketBase
PB_URL=http://127.0.0.1:8090
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=changeme

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# Server
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173,http://localhost:8090
NODE_ENV=development

# Encryption key for integration credentials stored in PocketBase.
# Generated automatically by the setup wizard — do NOT copy this to the frontend.
# Must be a 64-character hex string (32 bytes). Keep this secret.
AIDA_ENCRYPTION_KEY=
